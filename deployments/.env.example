# Copy to .env and set real values. Never commit .env.
# SQL Server SA password — min 8 chars incl. upper, lower, digit, symbol.
SA_PASSWORD=Change_This_Str0ng!Passw0rd

# Host port the production web UI listens on (default 80).
WEB_PORT=80

# Host port the test-stack web UI listens on (default 8080).
TEST_WEB_PORT=8080
